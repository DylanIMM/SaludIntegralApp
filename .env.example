# ====================================================
# CONFIGURACIÓN DE BASE DE DATOS DISTRIBUIDA
# ====================================================
# Este archivo contiene las variables de entorno necesarias
# para conectar la aplicación a SQL Server

# Puerto del servidor Node.js
PORT=3000

# ====================================================
# CONFIGURACIÓN DE CONEXIÓN A SQL SERVER - NODO LOCAL
# ====================================================
# Cambiar estos valores según tu configuración de SQL Server

# Usuario de SQL Server
DB_LOCAL_USER=usuario

# Contraseña del usuario de SQL Server
DB_LOCAL_PASSWORD=TuContraseña123

# Servidor SQL local 
DB_LOCAL_SERVER=localhost

# Nombre de la base de datos local
DB_LOCAL_DATABASE=mibase
