# ====================================================
# CONFIGURACIÓN DE BASE DE DATOS DISTRIBUIDA
# ====================================================
# Este archivo contiene las variables de entorno necesarias
# para conectar la aplicación a SQL Server

# Puerto del servidor Node.js
PORT=3000

# ====================================================
# CONFIGURACIÓN DE CONEXIÓN A SQL SERVER - NODO LOCAL
# ====================================================
# Cambiar estos valores según tu configuración de SQL Server

# Usuario de SQL Server (generalmente 'sa' o tu usuario)
DB_LOCAL_USER=usuario

# Contraseña del usuario de SQL Server
DB_LOCAL_PASSWORD=TuContraseña123

# Servidor SQL local (localhost, .\SQLEXPRESS, IP, SERVIDOR\INSTANCIA)
# Ejemplos:
#   - localhost
#   - .\SQLEXPRESS (para instancia local)
#   - DELL-PC\SQLEXPRESS (para instancia nombrada)
#   - 192.168.1.100 (para servidor remoto)
DB_LOCAL_SERVER=localhost

# Nombre de la base de datos local
# Para Nodo C01 (NORTE): SaludIntegralNorte
# Para Nodo C02 (CENTRO): SaludIntegralCentro
DB_LOCAL_DATABASE=database

# ====================================================
# CONFIGURACIÓN DE NODO REMOTO 
# ====================================================
# Servidor del Nodo 2 
# Ejemplos:
#   - 192.168.1.101 (otra máquina en la red)
#   - LAPTOP-C02 (nombre de computadora)
#   - c02.tudominio.local (dominio)
DB_REMOTE_SERVER=direccionIP

# Usuario del Nodo 2 
DB_REMOTE_USER=usuario

# Contraseña del Nodo 2
DB_REMOTE_PASSWORD=TuContraseña123

# Base de datos del Nodo 2
DB_REMOTE_DATABASE=database

