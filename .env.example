# ====================================================
# CONFIGURACIÓN DE BASE DE DATOS DISTRIBUIDA
# ====================================================
# Este archivo contiene las variables de entorno necesarias
# para conectar la aplicación a SQL Server

# Puerto del servidor Node.js
PORT=3000

# ====================================================
# CONFIGURACIÓN DE CONEXIÓN A SQL SERVER - NODO LOCAL
# ====================================================
# Cambiar estos valores según tu configuración de SQL Server

# Usuario de SQL Server (generalmente 'sa' o tu usuario)
DB_LOCAL_USER=sa

# Contraseña del usuario de SQL Server
DB_LOCAL_PASSWORD=TuContraseña123

# Servidor SQL local (localhost, .\SQLEXPRESS, IP, SERVIDOR\INSTANCIA)
# Ejemplos:
#   - localhost
#   - .\SQLEXPRESS (para instancia local)
#   - DELL-PC\SQLEXPRESS (para instancia nombrada)
#   - 192.168.1.100 (para servidor remoto)
DB_LOCAL_SERVER=localhost

# Nombre de la base de datos local
# Para Nodo C01 (NORTE): SaludIntegralNorte
# Para Nodo C02 (CENTRO): SaludIntegralCentro
DB_LOCAL_DATABASE=SaludIntegralNorte

# ====================================================
# CONFIGURACIÓN DE NODO REMOTO (OPCIONAL)
# ====================================================
# Si necesitas conectarte directamente a Nodo 2 desde esta aplicación
# (generalmente no es necesario si usas Linked Server)

# Habilitar conexión directa a Nodo 2 (true/false)
DB_REMOTE_ENABLED=false

# Servidor del Nodo 2 (solo si DB_REMOTE_ENABLED=true)
# Ejemplos:
#   - 192.168.1.101 (otra máquina en la red)
#   - LAPTOP-C02 (nombre de computadora)
#   - c02.tudominio.local (dominio)
DB_REMOTE_SERVER=192.168.1.101

# Usuario del Nodo 2 (mismo usuario si está en dominio)
DB_REMOTE_USER=sa

# Contraseña del Nodo 2
DB_REMOTE_PASSWORD=TuContraseña123

# Base de datos del Nodo 2
DB_REMOTE_DATABASE=SaludIntegralCentro

# ====================================================
# NOTAS IMPORTANTES
# ====================================================
# REPLICACIÓN:
# - Clínicas (Transaccional): C01 → C02 (gestionada por SQL Server)
# - Pacientes (Merge): C01 ↔ C02 (gestionada por SQL Server)
# - La app NO necesita conectar directamente a C02 si usa Linked Server
#
# LINKED SERVER:
# - Nodo C02 debe tener un Linked Server "NODO_C01" apuntando a este servidor
# - La sincronización se hace automáticamente en SQL Server
#
# NODO 1 (ACTUAL - NORTE - C01):
# - DB_LOCAL_DATABASE = SaludIntegralNorte
# - Esta aplicación corre en Nodo 1
# - La replicación hacia C02 es automática
#
# NODO 2 (CENTRO - C02):
# - Debe tener su propia instancia de esta aplicación
# - DB_LOCAL_DATABASE = SaludIntegralCentro
# - Opcional: Si la IP de C02 cambia, actualiza DB_REMOTE_SERVER
#
# CONEXIÓN DESDE APLICACIÓN:
# - Header 'x-sede' = 'C01' para consultar datos de Nodo 1
# - Header 'x-sede' = 'C02' para consultar datos de Nodo 2
# - El aplicativo automáticamente accede al fragmento correcto

